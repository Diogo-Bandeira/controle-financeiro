# Copie este arquivo para .env e preencha com suas credenciais do Supabase
# Encontre esses valores em: Supabase Dashboard > Project Settings > API

VITE_SUPABASE_URL="https://SEU_PROJECT_ID.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua_anon_public_key_aqui"
VITE_SUPABASE_PROJECT_ID="seu_project_id_aqui"
